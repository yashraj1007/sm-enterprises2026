# GEMINI_API_KEY: Required for Gemini AI API calls.
# Obtain your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted (e.g. http://localhost:3000)
# Used for self-referential links and constructing download URLs
APP_URL=http://localhost:3000

# Note: Firebase configuration is loaded from firebase-applet-config.json
# Ensure that file exists and is correct for your Firebase project.
