rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. GLOBAL CATCH-ALL SAFETY
    match /{document=**} {
      allow read, write: if false;
    }

    // --- SHARED REUSABLE LOGIC (PRIMITIVES) ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    // Identity & RBAC Root
    function isAdmin() { 
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email in ['yashrajbhore1107@gmail.com', 'bauchkarpranoti@gmail.com', 'testywebdevp@gmail.com']
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- SCHEMA VALIDATION BLUEPRINTS ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 100 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is string;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.category in ['laptop', 'accessory'] &&
             data.stock is number &&
             (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 400000)) &&
             (data.description == null || (data.description is string && data.description.size() <= 2000)) &&
             (data.specs == null || data.specs is map) &&
             data.createdAt is string;
    }

    function isValidOrder(data) {
      return data.customerEmail is string && data.customerEmail.size() <= 100 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 20 &&
             data.total is number &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             data.createdAt is string;
    }

    function isValidQuery(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.type in ['software', 'hardware'] &&
             data.problem is string && data.problem.size() <= 5000 &&
             data.status in ['pending', 'in-progress', 'resolved'] &&
             // Base64 evidence string limit to prevent DDOS-via-payload
             (data.problemImageUrl == null || (data.problemImageUrl is string && data.problemImageUrl.size() <= 400000)) &&
             data.createdAt is string;
    }

    // --- COLLECTION MATCH BLOCKS ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Tier 1: Registration
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == 'user' && 
                    incoming().keys().hasAll(['email', 'role', 'createdAt']) && 
                    incoming().keys().size() == 3;
      
      // Tier 2: Self-Maintenance
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['email']) &&
                    incoming().role == existing().role;
                    
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    match /orders/{orderId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidOrder(incoming()) && 
                    (incoming().userId == request.auth.uid || incoming().userId == 'manual-entry') &&
                    incoming().keys().hasAll(['customerEmail', 'items', 'total', 'status', 'createdAt', 'userId']);
      
      allow update: if isAdmin() || (
        isOwner(existing().userId) && 
        isValidOrder(incoming()) &&
        existing().status == 'pending' &&
        incoming().status == 'cancelled' &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
    }

    match /queries/{queryId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidQuery(incoming()) && 
                    incoming().userId == request.auth.uid &&
                    isValidId(queryId) &&
                    incoming().keys().hasAll(['name', 'email', 'type', 'problem', 'status', 'createdAt', 'userId']);
      
      allow update: if (
        isAdmin() && isValidQuery(incoming())
      ) || (
        isOwner(existing().userId) && 
        isValidQuery(incoming()) &&
        existing().status == 'pending' &&
        incoming().diff(existing()).affectedKeys().hasOnly(['problem'])
      );
      
      allow delete: if isAdmin();
    }

    match /contact_queries/{contactId} {
      allow create: if incoming().keys().hasAll(['name', 'email', 'subject', 'message', 'createdAt']);
      allow read, update, delete: if isAdmin();
    }
  }
}
